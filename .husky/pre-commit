#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run lint-staged for pre-commit checks
npx lint-staged

# Check for large files (>100KB)
echo "Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | xargs -I{} sh -c 'if [ -f "{}" ]; then SIZE=$(stat -f%z "{}" 2>/dev/null || stat -c%s "{}" 2>/dev/null); if [ "$SIZE" -gt 102400 ]; then echo "{} ($((SIZE / 1024))KB)"; fi; fi')

if [ -n "$LARGE_FILES" ]; then
  echo "ERROR: Large files detected (>100KB):"
  echo "$LARGE_FILES"
  echo "Consider using Git LFS for large files or breaking up the file."
  exit 1
fi

# Check for TODO/FIXME comments without issue references
echo "Checking tech debt markers..."
TODOS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | xargs grep -n "TODO\|FIXME" 2>/dev/null | grep -v "TODO([A-Z]*-[0-9]*)")

if [ -n "$TODOS" ]; then
  echo "WARNING: TODO/FIXME comments without issue references found:"
  echo "$TODOS"
  echo "Consider adding issue reference: TODO(PROJ-123)"
fi

# Check for secrets in staged files
echo "Checking for potential secrets..."
SECRETS=$(git diff --cached --name-only --diff-filter=ACM | xargs grep -lE "(password|secret|token|key|api[_-]?key)\s*=\s*[\"'][^\"']{8,}[\"']" 2>/dev/null || true)

if [ -n "$SECRETS" ]; then
  echo "WARNING: Potential secrets detected in:"
  echo "$SECRETS"
  echo "Please verify no actual secrets are committed."
fi

echo "Pre-commit checks completed."
